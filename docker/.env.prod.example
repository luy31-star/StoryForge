# ========== 基础 ==========
ENV=production
JWT_SECRET_KEY=f26b4380e7594a1694e12bdc9511d447

INIT_ADMIN_USERNAME=luy31
INIT_ADMIN_PASSWORD=cueite1025

# 前端域名/入口（用于 CORS；有域名就写域名，没有就先写公网 IP）
# 建议最终写：https://your-domain.com
CORS_ORIGINS=https://storyforge.asia,https://www.storyforge.asia

# Docker Hub 镜像前缀（国内可用 DaoCloud 镜像）
DOCKER_HUB_PREFIX=docker.m.daocloud.io/library

# ========== 数据库（RDS MySQL 杭州） ==========
DATABASE_URL=mysql+pymysql://user:pass@rm-bp13k5j262dqy7lby.mysql.rds.aliyuncs.com:3306/vocalflow?charset=utf8mb4

# ========== Redis（Tair/Redis 杭州） ==========
REDIS_URL=redis://user:pass@r-bp1inoyo1li6m6gh5k.redis.rds.aliyuncs.com:6379/0

# ========== 积分规则 ==========
POINTS_PER_CNY=10
REGISTER_INITIAL_POINTS=100

# ========== 邮箱验证码（163 SMTP） ==========
MAIL_SERVER=smtp.163.com
MAIL_PORT=465
MAIL_USERNAME=user@163.com
MAIL_PASSWORD=password
MAIL_FROM=user@163.com
MAIL_USE_TLS=false
MAIL_USE_SSL=true
OTP_EXPIRE_MINUTES=10

# ========== OSS（可选，没用就留空） ==========
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_REGION=cn-hangzhou
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=default-vocal-flow

# ========== 支付宝电脑网站支付（充值） ==========
ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_APP_ID=your_app_id
ALIPAY_PRIVATE_KEY_PATH=./secrets/alipay_app_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=./secrets/alipay_alipay_public_key.pem
ALIPAY_RETURN_URL=https://storyforge.asia/recharge
ALIPAY_NOTIFY_URL=https://storyforge.asia/api/billing/recharge/alipay-notify
ALIPAY_SIGN_TYPE=RSA2

# 对账兜底（建议开启）
ALIPAY_RECONCILE_ENABLED=false
ALIPAY_RECONCILE_INTERVAL_MINUTES=5
ALIPAY_RECONCILE_MIN_AGE_MINUTES=2
ALIPAY_RECONCILE_LOOKBACK_HOURS=24

# ========== 小说/任务相关（按需保留） ==========
NOVEL_CONSISTENCY_CHECK_CHAPTER=true
NOVEL_CONSISTENCY_CHECK_TEMPERATURE=0.15

AI302_BASE_URL=https://api.302.ai/v1
AI302_API_KEY=your_api_key
AI302_CHAT_MODEL=gemini-2.0-flash
AI302_NOVEL_MODEL=glm-4.7
AI302_NOVEL_WEB_SEARCH=true

LLM_PROVIDER=ai302