# 复制为项目根目录 .env 后供 docker compose 注入 backend / celery
# cp .env.example .env
#
# 与 backend/.env.example 含义一致；容器内会覆盖 DATABASE_URL / REDIS_URL（见 docker-compose.yml）
#
# 未设置时 compose/Dockerfile 默认从 DaoCloud 拉 Docker Hub 官方库（docker.m.daocloud.io/library）。
# 海外或需直连 Hub 时取消注释下一行：
# DOCKER_HUB_PREFIX=docker.io/library
# 若出现 DNS i/o timeout，先为 Docker 配置公共 DNS（见 docker/daemon.json.example）。

AI302_API_KEY=
AI302_BASE_URL=https://api.302.ai/v1
AI302_NOVEL_MODEL=Doubao-Seed-2.0-pro
AI302_NOVEL_WEB_SEARCH=true
NOVEL_RESOLVED_OPEN_PLOTS_LOG_RETENTION_CHAPTERS=20
# 可选：OSS、直连密钥等（见 backend/.env.example）
