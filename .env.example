# 复制为项目根目录 .env 后供 docker compose 注入 backend / celery
# cp .env.example .env
#
# 与 backend/.env.example 含义一致；容器内会覆盖 DATABASE_URL / REDIS_URL（见 docker-compose.yml）
#
# 未设置时 compose/Dockerfile 默认 docker.m.daocloud.io/library（国内拉 Hub 官方库）。
# 海外直连 Docker Hub 时设置：DOCKER_HUB_PREFIX=docker.io/library
# 若拉镜像 DNS i/o timeout，可配置公共 DNS（见 docker/daemon.json.example）。
#
# 前端 Docker 构建拉 npm 包用（已是国内 npmmirror，与上面 Docker 镜像前缀不同）。仍慢可换：
# NPM_REGISTRY=https://mirrors.cloud.tencent.com/npm/

AI302_API_KEY=
AI302_BASE_URL=https://api.302.ai/v1
AI302_NOVEL_MODEL=Doubao-Seed-2.0-pro
AI302_NOVEL_WEB_SEARCH=true
NOVEL_RESOLVED_OPEN_PLOTS_LOG_RETENTION_CHAPTERS=20
# 可选：OSS、直连密钥等（见 backend/.env.example）

# 支付宝电脑网站支付（积分充值）
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=./secrets/alipay_app_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=./secrets/alipay_alipay_public_key.pem
ALIPAY_RETURN_URL=http://localhost:3000/recharge
ALIPAY_NOTIFY_URL=http://localhost:8000/api/billing/recharge/alipay-notify
ALIPAY_SIGN_TYPE=RSA2
ALIPAY_RECONCILE_ENABLED=false
