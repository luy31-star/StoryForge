DATABASE_URL=mysql+pymysql://user:password@localhost:3306/vocalflow
# 本地开发可使用 SQLite:
# DATABASE_URL=sqlite:///./vocalflow.db
# 或 PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/vocalflow

REDIS_URL=redis://localhost:6379/0

# 302.AI 中转（推荐）：https://doc.302.ai/
AI302_BASE_URL=https://api.302.ai/v1
AI302_API_KEY=
AI302_CHAT_MODEL=Doubao-Seed-2.0-pro
AI302_NOVEL_MODEL=Doubao-Seed-2.0-pro
# 小说相关 Chat 是否附加 302 联网搜索（文档 https://doc.302.ai/260112819e0 ）
AI302_NOVEL_WEB_SEARCH=true
AI302_TTS_PATH=/audio/speech
AI302_TTS_MODEL=tts-1
# 在 302 文档中选择「视频/即梦/SeeDance」等接口后，把相对路径填在这里（无则仅排队不提交）
AI302_VIDEO_SUBMIT_PATH=

# 全局 LLM：在管理后台「模型计价」+「全局 LLM 设置」配置；以下为新建库时 app_config 初始值
LLM_PROVIDER=ai302
LLM_MODEL=

# 阿里云 OSS：SDK 从环境变量读 AK（见官方文档）
# export OSS_ACCESS_KEY_ID=...
# export OSS_ACCESS_KEY_SECRET=...
# 须与 Bucket 所在地域一致（控制台「Bucket 概览」可见），例如 cn-beijing、cn-hangzhou
OSS_REGION=cn-beijing
OSS_BUCKET=
# 可选；403 endpoint 错误时填控制台「外网访问」域名，例如 oss-cn-beijing.aliyuncs.com
OSS_ENDPOINT=
# 可选：CDN/自定义域名作为返回给前端的下载地址前缀
OSS_PUBLIC_BASE_URL=

JWT_SECRET_KEY=change-me
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 邮箱服务（注册验证码）
MAIL_SERVER=smtp.163.com
MAIL_PORT=465
MAIL_USERNAME=your_email@163.com
MAIL_PASSWORD=your_smtp_auth_code
MAIL_FROM=your_email@163.com
MAIL_USE_TLS=false
MAIL_USE_SSL=true
OTP_EXPIRE_MINUTES=10

# 小说：参考 txt 上限由 REFERENCE_TXT_MAX_BYTES 控制（默认 15MB）
REFERENCE_TXT_MAX_BYTES=15728640
NOVEL_LOCAL_UPLOAD_DIR=./uploads/novels
NOVEL_DAILY_DEFAULT_CHAPTERS=1
NOVEL_BEAT_HOUR=9
NOVEL_BEAT_MINUTE=0
# 单章续写：OpenAI 兼容接口 max_tokens（豆包/部分网关默认 completion 偏小时可调大，如 12288）
NOVEL_CHAPTER_MAX_TOKENS=8192
# 记忆合并摘要：参与合并的最近已审定章节数量（refresh_memory / 定时刷新）
NOVEL_MEMORY_REFRESH_CHAPTERS=15
# 记忆合并摘要：截取策略（tail | head | both），用于更偏向连续性
NOVEL_CHAPTER_SUMMARY_MODE=tail
# 记忆合并摘要：每章截取字符数（用于 tail/head/both）
NOVEL_CHAPTER_SUMMARY_TAIL_CHARS=3500
NOVEL_CHAPTER_SUMMARY_HEAD_CHARS=3500
# 冷热分层：写章时仅注入最近 N 条时间线（其余作为冷层保留在存储）
NOVEL_TIMELINE_HOT_N=20
NOVEL_OPEN_PLOTS_HOT_MAX=20
NOVEL_CHARACTERS_HOT_MAX=12
# 为 true 时 Celery Beat 在下方钟点批量刷新所有已确认框架且有审定章节的书的记忆（耗 token，默认关）
NOVEL_AUTO_REFRESH_MEMORY=false
NOVEL_MEMORY_BEAT_HOUR=10
NOVEL_MEMORY_BEAT_MINUTE=30
# 记忆刷新分批：每批摘要最大字符数（0 表示不分批）
NOVEL_MEMORY_REFRESH_BATCH_CHARS=15000
# 记忆刷新单批超时（秒）
NOVEL_MEMORY_REFRESH_BATCH_TIMEOUT=420.0
# 记忆增量抽取：单批返回 JSON 的 max_tokens
NOVEL_MEMORY_DELTA_MAX_TOKENS=4096
# 写章时默认附带最近完整正文的章节数
NOVEL_RECENT_FULL_CONTEXT_CHAPTERS=2
# 写章时按角色/线索/道具召回的历史条目数上限
NOVEL_MEMORY_ENTITY_RECALL_MAX_ITEMS=6

# 生成后一致性核对：会额外多一次 LLM 调用；稳成功率优先时建议关闭（默认关）
NOVEL_CONSISTENCY_CHECK_CHAPTER=false
# 一致性核对阶段温度（越低越“按规则改”，建议 0.1~0.4）
NOVEL_CONSISTENCY_CHECK_TEMPERATURE=0.25
